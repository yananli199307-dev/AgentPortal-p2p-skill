# Generated by develop/scripts/gen_envs.py — plain HTTP; browsers treat http://*.localhost as secure.
{
    auto_https off
}

http://:8443 {
    @lobster1 host lobster1.localhost
    handle @lobster1 {
        reverse_proxy lobster1:18789
    }
    @lobster2 host lobster2.localhost
    handle @lobster2 {
        reverse_proxy lobster2:18789
    }
    handle {
        respond "unknown host — use http://lobster{N}.localhost:18443" 404
    }
}
