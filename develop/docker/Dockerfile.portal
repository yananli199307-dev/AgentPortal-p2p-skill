FROM python:3.12-slim-bookworm

WORKDIR /app

RUN pip install --no-cache-dir fastapi uvicorn websockets requests pytz \
    || pip install --no-cache-dir -i https://mirrors.aliyun.com/pypi/simple/ --trusted-host mirrors.aliyun.com fastapi uvicorn websockets requests pytz

COPY . /app

EXPOSE 8080

CMD ["python", "-m", "uvicorn", "vps.main:app", "--host", "0.0.0.0", "--port", "8080"]
