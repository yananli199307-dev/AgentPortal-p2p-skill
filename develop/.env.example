# Copy to develop/.env — gen_envs.py reads these for every runtime/envN/gateway.env
#
# LOBSTER_API_KEY: Moonshot (Kimi K2) API key → also written as MOONSHOT_API_KEY for OpenClaw.
# LOBSTER_MODEL: e.g. kimi → moonshot/kimi-k2.5; moonshot/kimi-k2-turbo; kimi-code → kimi/kimi-code (+ KIMI_API_KEY).
# LOBSTER_MOONSHOT_REGION=intl — only if your key is for api.moonshot.ai; default is domestic https://api.moonshot.cn/v1.
# LOBSTER_MOONSHOT_BASE_URL=… — optional full override (legacy https://api.moonshot.ai/v1 is remapped to .cn unless REGION=intl).

LOBSTER_API_KEY=CHANGE_ME
LOBSTER_MODEL=kimi