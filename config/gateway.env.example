# Agent P2P 环境变量示例
# 复制此文件到 ~/.openclaw/gateway.env 并填入你的配置

# Agent Token（从 Portal 管理后台获取）
AGENTP2P_TOKEN=your-agent-token-here

# Portal 地址
AGENTP2P_HUB_URL=https://your-domain.com

# OpenClaw Gateway 地址
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789

# OpenClaw Hooks Token（从 ~/.openclaw/openclaw.json 获取）
OPENCLAW_HOOKS_TOKEN=your-hooks-token-here
